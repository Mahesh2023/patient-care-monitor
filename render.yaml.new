# Render blueprint — single-service, Docker build.
services:
  - type: web
    name: care-mm
    runtime: docker
    plan: free
    dockerfilePath: ./Dockerfile.new
    healthCheckPath: /health
    envVars:
      - key: PORT
        value: "8000"
      - key: LLM_PROVIDER
        value: groq
      - key: LLM_MODEL
        value: llama-3.3-70b-versatile
      - key: GROQ_API_KEY
        sync: false          # set in dashboard, never committed
      - key: ENABLE_LLM_REASONING
        value: "true"
      - key: LOG_LEVEL
        value: INFO
